# Server URL (can also be set in config.yaml)
MM_URL=https://mattermost.example.com

# Username (optional — will be prompted if not set)
# MM_USERNAME=your.username

# Personal Access Token — if set, skips the username/password prompt.
# Generate at: Profile > Security > Personal Access Tokens
# NEVER commit a real token.
# MM_TOKEN=your-personal-access-token-here

# Override output directory (can also be set in config.yaml)
# MM_OUTPUT=./archive
